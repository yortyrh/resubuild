# apps/api/.env.example
#
# Production env-var surface consumed by the release-1 docker compose target.
# Full documentation: openspec/specs/prod-env-bootstrap-helper/spec.md
# API contract:       openspec/specs/cv-rest-api/spec.md
#
# For local development use: `pnpm setup:env` (bash scripts/setup-local-env.sh)
# For release-1 production:  `pnpm setup:env:prod` (scripts/setup-prod-env.mjs)
#
# Keys written by the release-1 generator (scripts/setup-prod-env.mjs):
#
# Supabase
#   SUPABASE_URL              ConfigService → AuthService, all DB clients
#   SUPABASE_ANON_KEY         ConfigService → SupabaseAuthGuard, all API clients
#   SUPABASE_SERVICE_ROLE_KEY  ConfigService → MediaService, ExportStorageService (server-only)
#   SUPABASE_JWT_SECRET       ConfigService → SupabaseAuthService (optional, legacy)
#
# Storage
#   MEDIA_BUCKET              MediaService (required in production; optional in dev with warning)
#   MCP_EXPORT_BUCKET         ExportStorageService (required; throws 503 if unset)
#
# Server
#   PORT                      main.ts (NestJS bootstrap)
#   CORS_ORIGIN               MainAppGuard (CORS headers)
#   APP_URL                   MainAppGuard, cv-export service (PDF export, template URLs)
#   PUBLIC_API_URL            MediaService (absolute URL in media src attributes)
#
# PDF Export (Chromium)
#   CHROMIUM_EXECUTABLE_PATH  CvExportService (optional; omit to use Puppeteer bundled browser)
#
# MCP Server
#   MCP_KEY_PEPPER            McpAuthService (HMAC pepper; defaults to SUPABASE_SERVICE_ROLE_KEY)
#   MCP_SERVER_ENABLED         McpController (false → /mcp returns 404)
#   MCP_EXPORT_TTL_SECONDS    ExportStorageService.getDefaultTtlSeconds()
#   MCP_EXPORT_MAX_BYTES      ExportStorageService.getMaxBytes()
#
# AI / PDF Import
#   AI_AGENT_ENCRYPTION_KEY   AiAgentService (AES-256 per-user encryption key)
#   IMPORT_LLM_CONFIG_ENCRYPTION_KEY  AiAgentService (legacy alias, preferred)
#   PDF_IMPORT_MAX_BYTES      AiAgentService (default 5 MiB)
#   PDF_IMPORT_ENABLED        AiAgentService (default true)
#   IMPORT_MODELS_CATALOG_SOURCE  ImportModelsService ("static" for bundled-only)
#
# ---
#
# Local dev: `supabase start`, then `pnpm setup:env` from repo root.
# Or manually: `supabase status -o env`

# Required for Supabase Auth + database (RLS uses the user's Bearer token)
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Server-only: Storage uploads (`POST /media/upload`). Omit in dev only if uploads are unwanted (API logs a warning).
SUPABASE_SERVICE_ROLE_KEY=
MEDIA_BUCKET=

# Optional: max upload bytes (default 10 MiB); image MIME allowlist is enforced in code
# MEDIA_MAX_BYTES=

# Optional legacy JWT secret — no longer required for API auth validation
SUPABASE_JWT_SECRET=
PORT=3001
CORS_ORIGIN=http://localhost:3000
APP_URL=http://localhost:3000

# Absolute base URL clients use when embedding images (Markdown `src`). Should match browser reachability (often same origin as NEXT_PUBLIC_API_URL).
PUBLIC_API_URL=http://localhost:3001

# Optional: system Chromium for PDF export when bundled browser is unavailable (production Docker)
# CHROMIUM_EXECUTABLE_PATH=/usr/bin/chromium

# MCP API keys (HMAC pepper; defaults to SUPABASE_SERVICE_ROLE_KEY when unset)
# MCP_KEY_PEPPER=
# MCP_SERVER_ENABLED=true  # Disable the MCP server entirely. When false, /mcp returns 404 (server is not registered).
MCP_EXPORT_BUCKET=mcp-exports  # required for the `export_cv_*` MCP tools (must match a bucket in your Supabase project)
# MCP_EXPORT_TTL_SECONDS=3600    # default 1h signed-URL TTL
# MCP_EXPORT_MAX_BYTES=10485760  # default 10 MiB; cap is checked at upload time

# PDF import + per-user AI agent credentials (auto-filled by `pnpm setup:env`)
AI_AGENT_ENCRYPTION_KEY=change-me-to-a-long-random-secret
# Legacy alias still supported:
# IMPORT_LLM_CONFIG_ENCRYPTION_KEY=
# PDF_IMPORT_MAX_BYTES=5242880   # default 5 MiB
# PDF_IMPORT_ENABLED=true
# Set to `static` to use bundled catalog.json only (tests, offline).
# Otherwise the catalog is built from Mastra's model gateway + models.dev metadata.
# IMPORT_MODELS_CATALOG_SOURCE=
