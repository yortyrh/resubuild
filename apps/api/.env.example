# Local dev: `supabase start`, then `pnpm setup:env` from repo root.
# Or manually: `supabase status -o env`

# Required for Supabase Auth + database (RLS uses the user's Bearer token)
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Server-only: Storage uploads (`POST /media/upload`). Omit in dev only if uploads are unwanted (API logs a warning).
SUPABASE_SERVICE_ROLE_KEY=
MEDIA_BUCKET=

# Optional: max upload bytes (default 10 MiB); image MIME allowlist is enforced in code
# MEDIA_MAX_BYTES=

# Optional legacy JWT secret — no longer required for API auth validation
SUPABASE_JWT_SECRET=
PORT=3001
CORS_ORIGIN=http://localhost:3000
APP_URL=http://localhost:3000

# Absolute base URL clients use when embedding images (Markdown `src`). Should match browser reachability (often same origin as NEXT_PUBLIC_API_URL).
PUBLIC_API_URL=http://localhost:3001

# Optional: system Chromium for PDF export when bundled browser is unavailable (production Docker)
# CHROMIUM_EXECUTABLE_PATH=/usr/bin/chromium

# PDF import + per-user LLM settings (auto-filled by `pnpm setup:env`)
IMPORT_LLM_CONFIG_ENCRYPTION_KEY=change-me-to-a-long-random-secret
# SEARCH_API_KEY=              # optional Tavily key — prompted during setup:env
# PDF_IMPORT_MAX_BYTES=5242880   # default 5 MiB
# PDF_IMPORT_ENABLED=true
