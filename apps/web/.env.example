# Browser → API over CORS (Bearer JSON)
NEXT_PUBLIC_API_URL=http://localhost:3001

# Supabase browser client (for auth flows: passwordless, OTP, session mgmt)
# The publishable key is the ONLY Supabase key allowed in client bundles —
# service-role keys MUST stay in apps/api (server-only). The carve-out is
# enforced by apps/web/src/lib/web-bundle-security.test.ts.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Auth feature flags (client-only — the SPA renders the auth controls itself,
# no /auth/features endpoint round-trip). These mirror the values in
# apps/api/.env so the operator keeps both files in sync. The Next.js bundler
# inlines NEXT_PUBLIC_* at build time, so a re-deploy is required for the
# flags to change in production. Defaults: all off.
NEXT_PUBLIC_AUTH_FORGOT_PASSWORD_ENABLED=false
NEXT_PUBLIC_AUTH_EMAIL_VERIFICATION_ENABLED=false
NEXT_PUBLIC_AUTH_PASSWORDLESS_ENABLED=false
NEXT_PUBLIC_AUTH_GITHUB_OAUTH_ENABLED=false
# Google OAuth — see openspec/specs/auth-google-oauth/spec.md
NEXT_PUBLIC_AUTH_GOOGLE_OAUTH_ENABLED=false

# Optional: Mailpit URL for the dev-only auth email hint in the UI (default http://127.0.0.1:54324)
# NEXT_PUBLIC_DEV_MAILPIT_URL=http://127.0.0.1:54324
