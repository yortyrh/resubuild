{
  "name": "@resumind/import-agent",
  "version": "0.0.1",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch --preserveWatchOutput",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --coverage"
  },
  "dependencies": {
    "@mastra/core": "^0.20.2",
    "@resumind/import-models": "workspace:*",
    "@resumind/schemas": "workspace:*",
    "@resumind/types": "workspace:*",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "pdf-parse": "^1.1.1",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@types/pdf-parse": "^1.1.4",
    "@vitest/coverage-v8": "^3.2.4",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
