{
  "name": "resubuild",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "verify": "node scripts/check-node-version.mjs && pnpm format:check && pnpm lint && pnpm typecheck && pnpm test && pnpm build",
    "prepare": "lefthook install",
    "dev:web": "pnpm --filter @resubuild/web dev",
    "dev:api": "pnpm --filter @resubuild/api dev",
    "dev:api:debug": "pnpm --filter @resubuild/api start:debug",
    "local:devtools": "open http://localhost:3001/_devtools/",
    "dev:types": "pnpm --filter @resubuild/types dev",
    "setup:env": "bash scripts/setup-local-env.sh",
    "samples:pdf": "pnpm --filter @resubuild/resume-template build && node scripts/generate-sample-pdfs.mjs",
    "import-models:sync": "pnpm --filter @resubuild/import-models build && node scripts/sync-import-models.mjs",
    "samples:seed": "node scripts/seed-e2e-fixture.mjs",
    "local:credentials": "node scripts/show-local-credentials.mjs",
    "test:e2e": "pnpm --filter @resubuild/api test:e2e"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@supabase/supabase-js": "^2.50.0",
    "lefthook": "^2.1.8",
    "prettier": "^3.5.3",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "puppeteer": "^25.1.0",
    "sharp": "^0.34.5",
    "turbo": "^2.5.4"
  },
  "packageManager": "pnpm@10.26.0",
  "engines": {
    "node": "22.x"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "esbuild",
      "lefthook",
      "sharp",
      "unrs-resolver"
    ]
  }
}
