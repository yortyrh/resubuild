# GitHub OAuth — consumed by [auth.external.github] in config.toml via env() interpolation.
# NON-FUNCTIONAL stubs — replace with real credentials from a GitHub OAuth app
# (https://github.com/settings/developers). See openspec/specs/auth-github-oauth/spec.md.
GITHUB_OAUTH_CLIENT_ID=github-oauth-stub
GITHUB_OAUTH_SECRET=github-oauth-stub

# Google OAuth — consumed by [auth.external.google] in config.toml via env() interpolation.
# NON-FUNCTIONAL stubs — replace with real credentials from a Google OAuth app
# (https://console.cloud.google.com/apis/credentials). See openspec/specs/auth-google-oauth/spec.md.
GOOGLE_OAUTH_CLIENT_ID=google-oauth-stub
GOOGLE_OAUTH_SECRET=google-oauth-stub
